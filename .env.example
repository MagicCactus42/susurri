# Copy to .env and fill in real values. .env is gitignored.
# Used by docker-compose.yaml for the local Postgres instance.
POSTGRES_USER=susurri
POSTGRES_PASSWORD=change-me-to-a-strong-secret
POSTGRES_DB=susurri

# The CLI reads the Users DB connection string from this env var
# (or dotnet user-secrets). Must match the compose values above.
# SUSURRI_USERSDB_CONNECTION=Host=localhost;Port=5432;Database=susurri;Username=susurri;Password=change-me-to-a-strong-secret
