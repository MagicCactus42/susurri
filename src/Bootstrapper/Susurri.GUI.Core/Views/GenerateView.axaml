<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Susurri.GUI.ViewModels"
             x:Class="Susurri.GUI.Views.GenerateView"
             x:DataType="vm:GenerateViewModel"
             Background="{StaticResource GroundBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="560" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24,48">
            <TextBlock Classes="cond" Text="NEW IDENTITY" FontSize="22" LetterSpacing="8"
                       HorizontalAlignment="Center" Margin="8,0,0,6" />
            <TextBlock Classes="label" Text="A BIP39 PASSPHRASE IS THE ENTIRE ACCOUNT"
                       FontSize="10" LetterSpacing="2.2" HorizontalAlignment="Center" Margin="0,0,0,30" />

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,22">
                <TextBlock Classes="label" Text="WORDS" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding WordCounts}" SelectedItem="{Binding SelectedWordCount}"
                          MinWidth="84" />
                <Button Classes="ice" Content="GENERATE" Command="{Binding GenerateCommand}" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding Words}" IsVisible="{Binding HasWords}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:WordItem">
                        <Border Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1"
                                Margin="3" Padding="10,7">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="mut" FontSize="10" VerticalAlignment="Center"
                                           Text="{Binding Index}" />
                                <TextBlock Classes="ice" FontSize="13" Text="{Binding Word}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Classes="dim" FontSize="11.5" Text="{Binding EntropyText}"
                       IsVisible="{Binding HasWords}" HorizontalAlignment="Center" Margin="0,12,0,0" />

            <StackPanel IsVisible="{Binding HasWords}" Spacing="4" Margin="0,20,0,0">
                <TextBlock Classes="amber" FontSize="12" TextWrapping="Wrap"
                           Text="▲ Write this down and store it securely offline." />
                <TextBlock Classes="amber" FontSize="12" TextWrapping="Wrap"
                           Text="▲ The passphrase is your identity — lose it and access is gone forever." />
                <TextBlock Classes="amber" FontSize="12" TextWrapping="Wrap"
                           Text="▲ Anyone holding it can impersonate you. There is no reset." />
            </StackPanel>

            <TextBlock Classes="err" Text="{Binding Error}" IsVisible="{Binding HasError}"
                       TextWrapping="Wrap" FontSize="12" Margin="0,14,0,0" />

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,26,0,0">
                <Button Classes="ghost" Content="COPY TO CLIPBOARD" Command="{Binding CopyCommand}" />
                <TextBlock Classes="ok" Text="copied ✓" FontSize="12" VerticalAlignment="Center"
                           IsVisible="{Binding Copied}" />
            </StackPanel>
            <Button Classes="link" Content="← back to login" Command="{Binding BackCommand}"
                    HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="12" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
